# Set default behavior to automatically normalize line endings
* text=auto

# Force LF endings for source code files (cross-platform safe)
*.py     text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf

# Force CRLF endings for Windows-specific scripts (optional)
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files – do not modify line endings
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.tar.gz binary
*.exe    binary
*.dll    binary
